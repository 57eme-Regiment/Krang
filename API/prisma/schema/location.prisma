model Location {
  id            String  @id @default(uuid())
  type          LocationType
  faction       Faction

  iconType      Int     @default(0)
  flags         Int     @default(0)
  viewDirection Int     @default(0)

  longitude     Float //X repésente Est-Ouest
  latitude      Float //Y Repésente Nord/Sud

  regionId      String
  region        Region    @relation(fields: [regionId], references: [id])

  townId        String
  town          Town      @relation(fields: [townId], references: [id])

  @@unique([longitude, latitude])
}
