{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0", // TODO : Fucking remove it before production
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@57eme-regiment/krang-api-contract": ["packages/contract/src/index.ts"],
      "@57eme-regiment/krang-api-contract/*": ["packages/contract/src/*"]
    }
  },
  "include": ["src/**/*", "packages/contract/src/**/*"],
  "exclude": ["node_modules", "dist", "packages/contract/dist"]
}
